# ─── User Auth Microservice — Environment Variables ──────────────────────────
# Copy this file to .env for local development:
#   cp .env.example .env
#
# In production (AWS ECS), inject these via:
#   - ECS Task Definition "environment" field (non-secret values)
#   - AWS Secrets Manager / SSM Parameter Store (secrets)
# ─────────────────────────────────────────────────────────────────────────────

# The port the HTTP server listens on
PORT=3001

# Secret used to sign and verify JWTs.
# MUST be a long, random, cryptographically strong string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_strong_random_secret_before_deploying

# How long issued JWTs remain valid (jsonwebtoken "expiresIn" format)
# Examples: 1h, 15m, 7d
JWT_EXPIRES_IN=1h

# CORS allowed origin. Use '*' only for development.
# In production, set this to your frontend domain, e.g.: https://app.example.com
CORS_ORIGIN=*

# Node environment — controls logging verbosity and error detail
NODE_ENV=development
